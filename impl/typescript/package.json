{
  "name": "pairl",
  "version": "1.5.1",
  "description": "PAIRL \u2014 compact, lossless agent-to-agent message protocol. Parse, serialize, validate (V1\u2013V12), canonicalize/hash, and render.",
  "repository": {
    "type": "git",
    "url": "https://github.com/dwehrmann/PAIRL",
    "directory": "impl/typescript"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "pairl",
    "agent",
    "protocol",
    "compression",
    "llm"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
